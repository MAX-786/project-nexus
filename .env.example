# Project Nexus - Root Environment Variables
# Copy this file to .env.local and fill in your values
# Note: Do not commit .env.local to version control

# ---------------------------------------------------------
# Web Dashboard (Next.js)
# ---------------------------------------------------------
# Your Supabase project URL (e.g., https://[PROJECT_ID].supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here

# Your Supabase anonymous key map (Found in API settings)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# The base URL of the Next.js app 
# Local: http://localhost:3000
# Prod: https://your-project-nexus-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------
# Browser Extension (Plasmo)
# ---------------------------------------------------------
# Your Supabase project URL (Matches NEXT_PUBLIC_SUPABASE_URL)
PLASMO_PUBLIC_SUPABASE_URL=your_supabase_url_here

# Your Supabase anonymous key (Matches NEXT_PUBLIC_SUPABASE_ANON_KEY)
PLASMO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# The base URL of the Next.js app (Matches NEXT_PUBLIC_SITE_URL)
PLASMO_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------
# AI API Keys (Optional - BYOK Model)
# ---------------------------------------------------------
# Only needed if using the Vercel AI SDK directly on the 
# server, bypassing the client BYOK local storage model.

# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
